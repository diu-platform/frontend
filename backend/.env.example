# DIU OS Backend — environment variables reference
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Required fields cause startup failure if absent.
# Optional fields have safe defaults (documented below).

# === Required ===

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://diu:password@localhost:5432/diu_physics

# JWT signing secret (min 32 characters, use a random string in production)
JWT_SECRET=change_me_to_a_random_32_char_secret_here

# Deployer wallet private key for on-chain verify_researcher calls (never log/commit this)
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY_HERE

# === Optional (have defaults) ===

# Listening port (default: 3001)
PORT=3001

# Comma-separated allowed CORS origins (default: localhost:5173,localhost:3000)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Arbitrum RPC endpoint (default: Arbitrum Sepolia public RPC)
CHAIN_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# DIURegistry contract address on Arbitrum Sepolia
# Default: deployed address from CLAUDE.md
REGISTRY_CONTRACT_ADDRESS=0x49e1b11e1037e74113a7c0ccc41e3042d4691018

# === AI Tutor (optional — graceful fallback if absent) ===

# Anthropic API key for Quantum AI Tutor (POST /api/chat)
# If absent: /api/chat returns a stub message instead of calling Claude
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# System prompt for the Quantum AI Tutor.
# If absent: uses the built-in default prompt (see config.rs DEFAULT_QUANTUM_SYSTEM_PROMPT).
# Override to customise persona, tone, language policy, or domain scope.
QUANTUM_SYSTEM_PROMPT=You are Quantum — the AI tutor of DIU OS, a decentralized scientific education platform. Your role: explain quantum physics concepts clearly, connect theory to the interactive 3D simulations the user sees (double-slit experiment, quantum tunneling, hydrogen orbitals), and motivate exploration. Respond in the same language the user uses (Russian or English). Be concise (3-6 sentences max per reply), use analogies, never guess physical constants — say 'I'm not certain' instead. Do not hallucinate formulas.

# === ORCID OAuth 2.0 (optional — ORCID login disabled if absent) ===

# ORCID OAuth 2.0 credentials — register at https://info.orcid.org/register-a-client
# Use the Public API for development (sandbox: https://sandbox.orcid.org)
# If absent: GET /auth/orcid returns 503 Service Unavailable
ORCID_CLIENT_ID=APP-XXXXXXXXXXXX
ORCID_CLIENT_SECRET=your-orcid-client-secret

# Redirect URI — must exactly match the one registered in your ORCID application
# Default (local dev): http://localhost:3001/auth/orcid/callback
ORCID_REDIRECT_URI=http://localhost:3001/auth/orcid/callback
